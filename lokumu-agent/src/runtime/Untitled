import { parseToolCall } from "./toolProtocol";
import { runTool } from "./toolRunner";

export async function runAgentLoop(agent: any, task: string, maxSteps = 6) {
  let context = task;

  for (let step = 0; step < maxSteps; step++) {
    const raw = await agent.askLLM([
      { role: "system", content: agent.systemPrompt },
      { role: "user", content: context },
    ]);

    console.log("\n🧠 STEP", step);
    console.log(raw);

    let toolCall;

    try {
      toolCall = parseToolCall(raw);
    } catch {
      context = `ONLY OUTPUT JSON TOOL CALL`;
      continue;
    }

    if (toolCall.tool === "done") {
      return "DONE";
    }

    const result = await runTool(toolCall);

    const allowedTools = Object.keys(agent.tools ?? {});

    if ((result as any)?.error?.startsWith?.("UNKNOWN_TOOL")) {
      context = `
INVALID TOOL USED.

ALLOWED TOOLS:
${allowedTools.join(", ")}

RULES:
- only use allowed tools
- no python
- no execute
- only json output
`;
      continue;
    }

    context = `
TASK:
${task}

RESULT:
${JSON.stringify(result)}

If done:
{ "tool": "done", "args": {} }

Else continue.
`;
  }

  return "DONE";
}
