# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/lokumu?schema=public"

# JWT
JWT_SECRET="change-this-secret-in-production"

# LLM provider: ollama | hf
LLM_PROVIDER=ollama
HF_TOKEN=
HF_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
HF_INFERENCE_URL=https://router.huggingface.co
HF_ENDPOINT_URL=
HF_TIMEOUT_MS=120000
HF_FALLBACK_TO_OLLAMA=false

# HF AutoTrain (Phase B) — GPU payant sur HF Spaces ; laisser false en MVP
HF_AUTOTRAIN_ALLOW_PAID=false
HF_USERNAME=
HF_DATASET_ID=
HF_AUTOTRAIN_BASE_MODEL=Qwen/Qwen2.5-7B-Instruct
HF_AUTOTRAIN_PROJECT=lokumu-kit-lin-qwen
HF_AUTOTRAIN_BACKEND=spaces-t4-small
HF_AUTOTRAIN_EPOCHS=2
HF_AUTOTRAIN_MIN_DIALOGUES=5

# Ollama
OLLAMA_BASE_URL="http://localhost:11434"
PORT=7001
OLLAMA_MODEL=lokumu-kit-lin:latest
OLLAMA_FALLBACK_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_MS=120000
CONVERSATION_HISTORY_TURNS=10
RAG_TOP_K_VAGUE=8
RAG_TOP_K_PRECISE=3
TRAINING_AUTO_APPROVE=true
DEMO_USER_ID=

# Embeddings
EMBEDDING_FALLBACK_MOCK="false"

# Community demo behavior
COMMUNITY_AUTO_APPROVE="true"

# Optional
REDIS_URL="redis://localhost:6379"